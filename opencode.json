{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "prd-generator": "allow",
      "*": "allow"
    },
    "tool": {
      "feishu-mcp_*": "allow",
      "read": "allow",
      "write": "allow",
      "edit": "allow"
    }
  },
  "agent": {
    "default": {
      "model": "Mify-Anthropic/ppio/pa/claude-sonnet-4-6",
      "temperature": 0.3
    }
  },
  "command": {
    "generate-prd": {
      "description": "Generate a PRD from a Feishu BRD URL",
      "template": "Use the prd-generator skill. BRD URL: $ARGUMENTS",
      "skill": "prd-generator"
    }
  }
}
